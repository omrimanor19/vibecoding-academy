#!/bin/bash

set -euo pipefail

# codex-start-worktree
#
# Codex-specific helper for starting work in an isolated git worktree.
# Claude Code already has its own built-in worktree workflow, so this script
# is for Codex usage in this repo.
#
# Usage:
#   scripts/codex-start-worktree <worktree-name>
#
# Example:
#   scripts/codex-start-worktree landing-page
#
# What it does:
#   1. Creates .worktrees/<worktree-name>
#   2. Creates branch <worktree-name> if needed, otherwise reuses it
#   3. Runs npm install if package.json exists and node_modules is missing
#   4. Launches codex inside the new worktree
#
# Test mode:
#   Set CODEX_START_WORKTREE_SKIP_CODEX=1 to skip the final codex launch.

usage() {
  echo "Usage: $0 <worktree-name>" >&2
}

if [ "$#" -ne 1 ]; then
  usage
  exit 1
fi

NAME="$1"

if [ -z "$NAME" ]; then
  usage
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "Error: run this script from inside a git repository." >&2
  exit 1
}

cd "$REPO_ROOT"

WORKTREE_DIR=".worktrees/$NAME"
WORKTREE_PATH="$REPO_ROOT/$WORKTREE_DIR"
BRANCH_NAME="$NAME"

if ! git check-ignore -q .worktrees/test-path; then
  echo "Error: .worktrees/ is not ignored. Add it to .gitignore first." >&2
  exit 1
fi

if [ -e "$WORKTREE_PATH" ]; then
  echo "Error: worktree path already exists: $WORKTREE_PATH" >&2
  exit 1
fi

if git worktree list --porcelain | grep -Fq "branch refs/heads/$BRANCH_NAME"; then
  echo "Error: branch '$BRANCH_NAME' is already checked out in another worktree." >&2
  exit 1
fi

if git show-ref --verify --quiet "refs/heads/$BRANCH_NAME"; then
  git worktree add "$WORKTREE_DIR" "$BRANCH_NAME"
else
  git worktree add "$WORKTREE_DIR" -b "$BRANCH_NAME"
fi

if [ -f "$WORKTREE_PATH/package.json" ] && [ ! -d "$WORKTREE_PATH/node_modules" ]; then
  (
    cd "$WORKTREE_PATH"
    npm install
  )
fi

echo "Worktree ready at $WORKTREE_PATH"

if [ "${CODEX_START_WORKTREE_SKIP_CODEX:-0}" = "1" ]; then
  echo "Skipping codex launch because CODEX_START_WORKTREE_SKIP_CODEX=1"
  exit 0
fi

cd "$WORKTREE_PATH"
exec codex
